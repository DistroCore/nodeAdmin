          "refId": "A"
        },
        {
          "expr": "pgbouncer_pools_server_idle_connections",
          "legendFormat": "{{database}} idle",
          "refId": "B"
        },
        {
          "expr": "pgbouncer_pools_client_waiting_connections",
          "legendFormat": "{{database}} waiting",
          "refId": "C"
        }
      ],
      "title": "PgBouncer Connection Pool",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "degradation_active",
          "legendFormat": "{{feature}} degraded",
          "refId": "A"
        },
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "{{name}} breaker",
          "refId": "B"
        },
        {
          "expr": "backpressure_zone",
