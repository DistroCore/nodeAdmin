  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["nodeadmin"],
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 2,
        "query": "label_values(im_messages_appended_total, tenantId)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
